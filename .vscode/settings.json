{
    "code-runner.executorMap": {
        "c": "gcc -std=c2x $fullFileName -o $fileNameWithoutExt && ./$fileNameWithoutExt"
    },
    "C_Cpp.default.cStandard": "c23", 
    "C_Cpp.default.intelliSenseMode": "linux-gcc-x64"

    "files.associations": {
        "*.c": "c",
        "*.h": "c"
    }
}
